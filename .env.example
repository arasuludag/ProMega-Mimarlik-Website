# Sanity — copy to .env and fill in after creating a project (see README).
# projectId and dataset are NOT secret (the dataset is public), so they use the
# PUBLIC_ prefix and are safe to expose / commit to CI as plain env vars.
PUBLIC_SANITY_PROJECT_ID="your_project_id"
PUBLIC_SANITY_DATASET="production"

# Only used by scripts/migrate.mjs (one-time content import). This token has WRITE
# access — keep it secret, never commit it. Create it at sanity.io/manage.
SANITY_WRITE_TOKEN=""
