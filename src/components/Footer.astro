---
import type { SiteSettings } from '../lib/queries';
import SanityImage from './SanityImage.astro';

interface Props {
  settings: SiteSettings;
}
const { settings } = Astro.props;
const c = settings.contact ?? {};
const s = settings.social ?? {};
const year = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="container grid">
    <div class="col">
      {
        settings.logo?.asset?.url ? (
          <a href="/" class="footer-brand" aria-label="Promega Mimarlık">
            <SanityImage image={settings.logo} alt="Promega Mimarlık" class="footer-logo" maxWidth={320} plain />
          </a>
        ) : (
          <span class="wordmark">PROMEGA<span class="thin"> MİMARLIK</span></span>
        )
      }
      {settings.footerText && <p class="muted">{settings.footerText}</p>}
    </div>

    <div class="col">
      <h3 class="ftitle">İletişim</h3>
      {c.email && <a class="line" href={`mailto:${c.email}`}>{c.email}</a>}
      {c.phone && <a class="line" href={`tel:${c.phone.replace(/[^0-9+]/g, '')}`}>{c.phone}</a>}
      {c.address && <p class="line muted">{c.address}</p>}
    </div>

    <div class="col">
      <h3 class="ftitle">Takip Edin</h3>
      <div class="socials">
        {
          s.instagram && (
            <a href={s.instagram} aria-label="Instagram" target="_blank" rel="noopener">
              <svg viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="3" y="3" width="18" height="18" rx="5"/><circle cx="12" cy="12" r="4"/><circle cx="17.5" cy="6.5" r="1" fill="currentColor" stroke="none"/></svg>
            </a>
          )
        }
        {
          s.facebook && (
            <a href={s.facebook} aria-label="Facebook" target="_blank" rel="noopener">
              <svg viewBox="0 0 24 24" width="22" height="22" fill="currentColor"><path d="M22 12a10 10 0 1 0-11.6 9.9v-7H7.9V12h2.5V9.8c0-2.5 1.5-3.9 3.8-3.9 1.1 0 2.2.2 2.2.2v2.4h-1.2c-1.2 0-1.6.8-1.6 1.6V12h2.7l-.4 2.9h-2.3v7A10 10 0 0 0 22 12z"/></svg>
            </a>
          )
        }
        {
          s.youtube && (
            <a href={s.youtube} aria-label="YouTube" target="_blank" rel="noopener">
              <svg viewBox="0 0 24 24" width="22" height="22" fill="currentColor"><path d="M23 12s0-3.2-.4-4.7a2.5 2.5 0 0 0-1.8-1.8C19.3 5 12 5 12 5s-7.3 0-8.8.5A2.5 2.5 0 0 0 1.4 7.3 26 26 0 0 0 1 12c0 1.6 0 3.2.4 4.7a2.5 2.5 0 0 0 1.8 1.8C4.7 19 12 19 12 19s7.3 0 8.8-.5a2.5 2.5 0 0 0 1.8-1.8c.4-1.5.4-4.7.4-4.7zM9.8 15V9l5.2 3-5.2 3z"/></svg>
            </a>
          )
        }
      </div>
    </div>
  </div>
  <div class="container bottom">
    <span class="muted">© {year} Promega Mimarlık. Tüm hakları saklıdır.</span>
  </div>
</footer>

<style>
  .site-footer {
    border-top: 1px solid var(--border);
    background: #161616;
    padding-top: clamp(3rem, 7vw, 5rem);
    margin-top: 2rem;
  }
  .grid {
    display: grid;
    grid-template-columns: 1.4fr 1fr 1fr;
    gap: 2.5rem;
    padding-bottom: 3rem;
  }
  .footer-brand {
    display: inline-block;
    margin-bottom: 0.4rem;
  }
  .footer-logo {
    height: 42px;
    width: auto;
    object-fit: contain;
    background: none !important;
  }
  .wordmark {
    font-size: 1.2rem;
    font-weight: 400;
    letter-spacing: 0.18em;
  }
  .wordmark .thin {
    font-weight: 100;
    color: var(--text-muted);
  }
  .ftitle {
    font-size: 0.78rem;
    letter-spacing: 0.24em;
    text-transform: uppercase;
    color: var(--text-muted);
    font-weight: 400;
    margin-bottom: 1rem;
  }
  .line {
    display: block;
    margin-bottom: 0.6rem;
    transition: opacity 0.25s var(--ease);
  }
  a.line:hover {
    opacity: 0.7;
  }
  .muted {
    color: var(--text-muted);
  }
  .socials {
    display: flex;
    gap: 1rem;
  }
  .socials a {
    color: var(--text-muted);
    transition: color 0.25s var(--ease), transform 0.25s var(--ease);
  }
  .socials a:hover {
    color: var(--text);
    transform: translateY(-2px);
  }
  .bottom {
    border-top: 1px solid var(--border);
    padding-block: 1.5rem;
    font-size: 0.85rem;
  }
  @media (max-width: 760px) {
    .grid {
      grid-template-columns: 1fr;
      gap: 2rem;
    }
  }
</style>
