---
import SanityImage from './SanityImage.astro';
import type { ImageWithMeta } from '../lib/image';

interface Props {
  images?: ImageWithMeta[];
  sloganLines?: string[];
}
const { images = [], sloganLines = [] } = Astro.props;
---

<section class="hero">
  <div class="embla" id="hero-embla">
    <div class="embla__viewport">
      <div class="embla__container">
        {
          images.map((img, i) => (
            <div class="embla__slide">
              <SanityImage
                image={img}
                class="hero-img"
                sizes="100vw"
                loading={i === 0 ? 'eager' : 'lazy'}
                aspect={16 / 9}
                maxWidth={2400}
              />
            </div>
          ))
        }
      </div>
    </div>
    <div class="hero-overlay"></div>
  </div>

  <div class="container hero-content">
    {
      sloganLines.length > 0 && (
        <h1 class="slogan">
          {sloganLines.map((line) => (
            <span class="slogan-line">{line}</span>
          ))}
        </h1>
      )
    }
  </div>

  <a href="#icerik" class="scroll-cue" aria-label="Aşağı kaydır">
    <span></span>
  </a>
</section>

<style>
  .hero {
    position: relative;
    height: min(92vh, 900px);
    min-height: 520px;
    overflow: hidden;
    background: #111;
  }
  .embla,
  .embla__viewport,
  .embla__container,
  .embla__slide {
    position: absolute;
    inset: 0;
    height: 100%;
  }
  .embla__viewport {
    overflow: hidden;
  }
  .embla__container {
    display: flex;
  }
  .embla__slide {
    position: relative;
    flex: 0 0 100%;
    min-width: 0;
  }
  .hero :global(.hero-img) {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transform: scale(1.04);
    animation: kenburns 9s ease-out forwards;
  }
  @keyframes kenburns {
    to {
      transform: scale(1);
    }
  }
  .hero-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      180deg,
      rgba(0, 0, 0, 0.35) 0%,
      rgba(0, 0, 0, 0.1) 40%,
      rgba(27, 27, 27, 0.85) 100%
    );
    pointer-events: none;
  }
  .hero-content {
    position: absolute;
    inset: auto 0 clamp(3rem, 9vh, 7rem) 0;
    z-index: 2;
  }
  .slogan {
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.1em;
    color: #fff;
    text-shadow: 0 2px 30px rgba(0, 0, 0, 0.4);
  }
  .slogan-line {
    font-weight: 100;
    font-size: clamp(2rem, 6.5vw, 4.5rem);
    line-height: 1.05;
    opacity: 0;
    transform: translateY(28px);
    animation: rise 1s var(--ease) forwards;
  }
  .slogan-line:nth-child(2) {
    font-weight: 400;
    animation-delay: 0.15s;
  }
  .slogan-line:nth-child(3) {
    animation-delay: 0.3s;
  }
  @keyframes rise {
    to {
      opacity: 1;
      transform: none;
    }
  }
  .scroll-cue {
    position: absolute;
    left: 50%;
    bottom: 1.6rem;
    transform: translateX(-50%);
    z-index: 2;
    width: 26px;
    height: 42px;
    border: 1.5px solid rgba(255, 255, 255, 0.6);
    border-radius: 14px;
  }
  .scroll-cue span {
    position: absolute;
    left: 50%;
    top: 8px;
    width: 3px;
    height: 8px;
    margin-left: -1.5px;
    background: #fff;
    border-radius: 2px;
    animation: cue 1.6s ease-in-out infinite;
  }
  @keyframes cue {
    0% {
      opacity: 0;
      transform: translateY(0);
    }
    40% {
      opacity: 1;
    }
    100% {
      opacity: 0;
      transform: translateY(14px);
    }
  }
  @media (prefers-reduced-motion: reduce) {
    .hero :global(.hero-img),
    .slogan-line,
    .scroll-cue span {
      animation: none;
    }
    .slogan-line {
      opacity: 1;
      transform: none;
    }
  }
</style>

<script>
  import EmblaCarousel from 'embla-carousel';
  import Autoplay from 'embla-carousel-autoplay';
  import Fade from 'embla-carousel-fade';

  const node = document.getElementById('hero-embla');
  const viewport = node?.querySelector('.embla__viewport') as HTMLElement | null;
  const slides = node?.querySelectorAll('.embla__slide') ?? [];
  if (viewport && slides.length > 1) {
    EmblaCarousel(viewport, { loop: true, duration: 40 }, [
      Autoplay({ delay: 5000, stopOnInteraction: false }),
      Fade(),
    ]);
  }
</script>
