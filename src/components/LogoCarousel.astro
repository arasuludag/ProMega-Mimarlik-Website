---
import SanityImage from './SanityImage.astro';
import type { ReferenceLogo } from '../lib/queries';

interface Props {
  logos?: ReferenceLogo[];
}
const { logos = [] } = Astro.props;
---

{
  logos.length > 0 && (
    <div class="embla-logos" id="logos-embla">
      <div class="embla__viewport">
        <div class="embla__container">
          {logos.map((l) => (
            <div class="logo-slide">
              {l.link ? (
                <a href={l.link} target="_blank" rel="noopener" class="logo-tile" title={l.name}>
                  <SanityImage image={l.logo} alt={l.name} maxWidth={400} sizes="200px" />
                </a>
              ) : (
                <div class="logo-tile" title={l.name}>
                  <SanityImage image={l.logo} alt={l.name} maxWidth={400} sizes="200px" />
                </div>
              )}
            </div>
          ))}
        </div>
      </div>
    </div>
  )
}

<style>
  .embla-logos {
    overflow: hidden;
    -webkit-mask-image: linear-gradient(
      90deg,
      transparent,
      #000 8%,
      #000 92%,
      transparent
    );
    mask-image: linear-gradient(90deg, transparent, #000 8%, #000 92%, transparent);
  }
  .embla__viewport {
    overflow: hidden;
  }
  .embla__container {
    display: flex;
    align-items: center;
  }
  .logo-slide {
    flex: 0 0 auto;
    padding: 0 0.6rem;
  }
  .logo-tile {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 180px;
    height: 110px;
    padding: 1.1rem 1.4rem;
    background: #f4f4f4;
    border-radius: 8px;
    transition: transform 0.3s var(--ease), box-shadow 0.3s var(--ease);
  }
  .logo-tile :global(img) {
    max-width: 100%;
    max-height: 100%;
    width: auto;
    height: auto;
    object-fit: contain;
    filter: grayscale(1);
    opacity: 0.75;
    transition: filter 0.3s var(--ease), opacity 0.3s var(--ease);
    background: none !important;
  }
  .logo-tile:hover {
    transform: translateY(-4px);
    box-shadow: 0 12px 30px rgba(0, 0, 0, 0.35);
  }
  .logo-tile:hover :global(img) {
    filter: grayscale(0);
    opacity: 1;
  }
</style>

<script>
  import EmblaCarousel from 'embla-carousel';
  import AutoScroll from 'embla-carousel-auto-scroll';

  const node = document.getElementById('logos-embla');
  const viewport = node?.querySelector('.embla__viewport') as HTMLElement | null;
  const slides = node?.querySelectorAll('.logo-slide') ?? [];
  const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  if (viewport && slides.length > 2 && !reduce) {
    EmblaCarousel(viewport, { loop: true, dragFree: true, align: 'start' }, [
      AutoScroll({ speed: 1, stopOnInteraction: false, stopOnMouseEnter: true }),
    ]);
  }
</script>
