---
import SanityImage from './SanityImage.astro';
import type { Project } from '../lib/queries';

interface Props {
  project: Project;
  sizes?: string;
}
const { project, sizes = '(max-width: 700px) 100vw, (max-width: 1100px) 50vw, 33vw' } =
  Astro.props;
const cover = project.images?.[0];
---

<a href={`/projeler/${project.slug}`} class="card reveal">
  <div class="card-media">
    {cover && <SanityImage image={cover} alt={project.title} class="cover" aspect={4 / 3} sizes={sizes} maxWidth={1200} />}
    <div class="card-overlay">
      <span class="view">Görüntüle</span>
    </div>
  </div>
  <div class="card-body">
    <h3 class="card-title">{project.title}</h3>
    <p class="card-meta">
      {project.location}
      {project.location && project.year ? ' · ' : ''}
      {project.year}
    </p>
  </div>
</a>

<style>
  .card {
    display: block;
    color: var(--text);
  }
  .card-media {
    position: relative;
    overflow: hidden;
    border-radius: 6px;
    background: var(--bg-elevated);
    aspect-ratio: 4 / 3;
  }
  .card :global(.cover) {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.7s var(--ease);
  }
  .card-overlay {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    background: linear-gradient(
      180deg,
      rgba(0, 0, 0, 0) 40%,
      rgba(0, 0, 0, 0.55) 100%
    );
    opacity: 0;
    transition: opacity 0.4s var(--ease);
  }
  .view {
    font-size: 0.78rem;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: #fff;
    border: 1px solid rgba(255, 255, 255, 0.7);
    padding: 0.6rem 1.2rem;
    border-radius: 2px;
    transform: translateY(10px);
    transition: transform 0.4s var(--ease);
  }
  .card:hover :global(.cover) {
    transform: scale(1.06);
  }
  .card:hover .card-overlay,
  .card:focus-visible .card-overlay {
    opacity: 1;
  }
  .card:hover .view {
    transform: none;
  }
  .card-body {
    padding: 1rem 0.1rem 0;
  }
  .card-title {
    font-size: 1.15rem;
    font-weight: 300;
    margin: 0 0 0.25rem;
  }
  .card-meta {
    margin: 0;
    color: var(--text-muted);
    font-size: 0.9rem;
    letter-spacing: 0.02em;
  }
</style>
