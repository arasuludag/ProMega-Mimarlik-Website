---
import Base from '../layouts/Base.astro';
import RichText from '../components/RichText.astro';
import SanityImage from '../components/SanityImage.astro';
import { getAboutPage } from '../lib/queries';

const about = await getAboutPage();
const heading = about.heading || 'Hakkımızda';
const cover = about.images?.[0];
const rest = (about.images ?? []).slice(1);
---

<Base title="Hakkımızda" description="Promega Mimarlık hakkında — 1990’dan bu yana mimarlık ve mühendislik.">
  <section class="section">
    <div class="container">
      <header class="page-head reveal">
        <p class="eyebrow">Biz Kimiz</p>
        <h1>{heading}</h1>
      </header>

      <div class="layout">
        <div class="text reveal">
          {
            about.body && about.body.length > 0 ? (
              <RichText value={about.body} />
            ) : (
              <p class="muted">
                1990 yılında Karabulut İnşaat Mimarlık adıyla hizmet vermeye başlayan
                ofis, 2007 yılından itibaren Promega Mimarlık Mühendislik olarak
                hizmet vermeye devam etmektedir.
              </p>
            )
          }
        </div>
        {
          cover && (
            <div class="media reveal">
              <SanityImage image={cover} alt={cover.alt || heading} sizes="(max-width: 900px) 100vw, 50vw" maxWidth={1400} />
            </div>
          )
        }
      </div>

      {
        rest.length > 0 && (
          <div class="more">
            {rest.map((img) => (
              <div class="reveal">
                <SanityImage image={img} alt={img.alt || heading} sizes="(max-width: 900px) 100vw, 50vw" maxWidth={1400} />
              </div>
            ))}
          </div>
        )
      }
    </div>
  </section>
</Base>

<style>
  .page-head {
    margin-bottom: clamp(2rem, 5vw, 3.5rem);
  }
  .layout {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: clamp(1.5rem, 4vw, 3.5rem);
    align-items: start;
  }
  .text {
    font-size: 1.05rem;
    line-height: 1.85;
    color: var(--text-muted);
  }
  .media :global(img),
  .more :global(img) {
    width: 100%;
    height: auto;
    border-radius: 6px;
  }
  .more {
    margin-top: 2rem;
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: clamp(1rem, 2.5vw, 2rem);
  }
  .muted {
    color: var(--text-muted);
  }
  @media (max-width: 900px) {
    .layout,
    .more {
      grid-template-columns: 1fr;
    }
  }
</style>
