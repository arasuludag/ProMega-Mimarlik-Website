---
import Base from '../layouts/Base.astro';
import RichText from '../components/RichText.astro';
import SanityImage from '../components/SanityImage.astro';
import { getServices } from '../lib/queries';

const services = await getServices();
---

<Base title="Hizmetler" description="Promega Mimarlık hizmetleri — mimari proje, iç mimari, mühendislik ve uygulama.">
  <section class="section">
    <div class="container">
      <header class="page-head reveal">
        <p class="eyebrow">Ne Yapıyoruz</p>
        <h1>Hizmetler</h1>
      </header>

      {
        services.length > 0 ? (
          <div class="grid">
            {services.map((s, i) => (
              <article class="card reveal">
                {s.icon?.asset?.url ? (
                  <div class="icon">
                    <SanityImage image={s.icon} alt={s.title} maxWidth={200} sizes="64px" plain />
                  </div>
                ) : (
                  <div class="icon icon--num">{String(i + 1).padStart(2, '0')}</div>
                )}
                <h3>{s.title}</h3>
                {s.description && <RichText value={s.description} class="card-text" />}
              </article>
            ))}
          </div>
        ) : (
          <p class="muted">Hizmet içerikleri yakında eklenecektir.</p>
        )
      }
    </div>
  </section>
</Base>

<style>
  .page-head {
    margin-bottom: clamp(2rem, 5vw, 3.5rem);
  }
  .grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(min(360px, 100%), 1fr));
    gap: clamp(1rem, 2.5vw, 1.6rem);
  }
  .card {
    background: var(--bg-elevated);
    border: 1px solid var(--border);
    border-radius: 8px;
    padding: 2rem 1.8rem;
    transition: transform 0.35s var(--ease), border-color 0.35s var(--ease),
      background 0.35s var(--ease);
  }
  .card:hover {
    transform: translateY(-6px);
    border-color: var(--accent);
    background: var(--bg-elevated-2);
  }
  .icon {
    width: 64px;
    height: 64px;
    margin-bottom: 1.4rem;
    display: grid;
    place-items: center;
    border-radius: 50%;
    background: var(--bg-elevated-2);
    border: 1px solid var(--border);
    padding: 14px;
    transition: border-color 0.35s var(--ease);
  }
  .card:hover .icon {
    border-color: var(--accent);
  }
  .icon :global(img) {
    width: 100%;
    height: 100%;
    object-fit: contain;
    background: none !important;
  }
  .icon--num {
    padding: 0;
    font-size: 1.15rem;
    font-weight: 300;
    letter-spacing: 0.08em;
    color: var(--accent);
  }
  .card h3 {
    font-size: 1.3rem;
    font-weight: 300;
    margin-bottom: 0.6rem;
  }
  .card :global(.card-text) {
    color: var(--text-muted);
    font-size: 0.98rem;
  }
  .muted {
    color: var(--text-muted);
  }
</style>
