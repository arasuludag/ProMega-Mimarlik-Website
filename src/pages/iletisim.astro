---
import Base from '../layouts/Base.astro';
import { getSiteSettings } from '../lib/queries';

const settings = await getSiteSettings();
const c = settings.contact ?? {};
const s = settings.social ?? {};
const mapQuery = c.address ? encodeURIComponent(c.address) : '';
---

<Base title="İletişim" description="Promega Mimarlık ile iletişime geçin.">
  <section class="section">
    <div class="container">
      <header class="page-head reveal">
        <p class="eyebrow">Bize Ulaşın</p>
        <h1>İletişim</h1>
      </header>

      <div class="layout">
        <div class="details reveal">
          {
            c.email && (
              <div class="block">
                <span class="label">E-posta</span>
                <a href={`mailto:${c.email}`}>{c.email}</a>
              </div>
            )
          }
          {
            c.phone && (
              <div class="block">
                <span class="label">Telefon</span>
                <a href={`tel:${c.phone.replace(/[^0-9+]/g, '')}`}>{c.phone}</a>
              </div>
            )
          }
          {
            c.address && (
              <div class="block">
                <span class="label">Adres</span>
                <p>{c.address}</p>
              </div>
            )
          }
          {
            (s.instagram || s.facebook || s.youtube) && (
              <div class="block">
                <span class="label">Sosyal Medya</span>
                <div class="socials">
                  {s.instagram && <a href={s.instagram} target="_blank" rel="noopener">Instagram</a>}
                  {s.facebook && <a href={s.facebook} target="_blank" rel="noopener">Facebook</a>}
                  {s.youtube && <a href={s.youtube} target="_blank" rel="noopener">YouTube</a>}
                </div>
              </div>
            )
          }
        </div>

        {
          mapQuery && (
            <div class="map reveal">
              <iframe
                title="Harita"
                src={`https://maps.google.com/maps?q=${mapQuery}&z=15&output=embed`}
                loading="lazy"
                referrerpolicy="no-referrer-when-downgrade"
              />
            </div>
          )
        }
      </div>
    </div>
  </section>
</Base>

<style>
  .page-head {
    margin-bottom: clamp(2rem, 5vw, 3.5rem);
  }
  .layout {
    display: grid;
    grid-template-columns: 1fr 1.2fr;
    gap: clamp(1.5rem, 4vw, 3.5rem);
    align-items: start;
  }
  .block {
    margin-bottom: 2rem;
  }
  .label {
    display: block;
    font-size: 0.75rem;
    letter-spacing: 0.24em;
    text-transform: uppercase;
    color: var(--text-muted);
    margin-bottom: 0.5rem;
  }
  .block a,
  .block p {
    font-size: 1.15rem;
    font-weight: 300;
    margin: 0;
  }
  .block a {
    transition: opacity 0.25s var(--ease);
  }
  .block a:hover {
    opacity: 0.7;
  }
  .socials {
    display: flex;
    gap: 1.4rem;
  }
  .socials a {
    font-size: 1rem;
    position: relative;
  }
  .socials a::after {
    content: '';
    position: absolute;
    left: 0;
    bottom: -3px;
    width: 100%;
    height: 1px;
    background: currentColor;
    transform: scaleX(0);
    transform-origin: left;
    transition: transform 0.3s var(--ease);
  }
  .socials a:hover::after {
    transform: scaleX(1);
  }
  .map {
    border-radius: 8px;
    overflow: hidden;
    border: 1px solid var(--border);
    min-height: 380px;
    background: var(--bg-elevated);
  }
  .map iframe {
    width: 100%;
    height: 100%;
    min-height: 380px;
    border: 0;
    display: block;
    filter: grayscale(1) invert(0.92) contrast(0.9);
  }
  @media (max-width: 860px) {
    .layout {
      grid-template-columns: 1fr;
    }
  }
</style>
