---
import Base from '../layouts/Base.astro';
import HeroSlider from '../components/HeroSlider.astro';
import ProjectCard from '../components/ProjectCard.astro';
import SanityImage from '../components/SanityImage.astro';
import RichText from '../components/RichText.astro';
import { getSiteSettings, getProjects, getReferenceLogos, getAboutPage, getTeam } from '../lib/queries';

const settings = await getSiteSettings();
const allProjects = await getProjects();
const logos = await getReferenceLogos();
const about = await getAboutPage();
const team = await getTeam();

const featured = allProjects.filter((p) => p.featured);
const showcase = (featured.length ? featured : allProjects).slice(0, 4);

const sloganLines = settings.sloganLines?.length
  ? settings.sloganLines
  : ['Mimarlık · Mühendislik', '& İç Mimarlık'];

const intro = settings.homeIntro ?? {};
const introImage = intro.image ?? about.images?.[0];
const introText =
  intro.text ??
  "1990'dan bu yana mimarlık, mühendislik ve iç mimarlık alanlarında özgün, estetik ve yaşanabilir projeler üretiyoruz.";
const introBtnLabel = intro.buttonLabel || 'Projeleri İncele';
const introBtnLink = intro.buttonLink || '/projeler';
const aboutImage = about.images?.[1] ?? about.images?.[0];
---

<Base transparentHeader>
  <HeroSlider images={settings.heroImages} sloganLines={sloganLines} />

  <!-- References: slow marquee just under the hero -->
  {
    logos.length > 0 && (
      <section class="refs-marquee" aria-label="Referanslar">
        <span class="refs-label">Referanslar</span>
        <div class="marquee">
          <div class="marquee-track">
            {[...logos, ...logos].map((l, i) => (
              <div class="marquee-item" aria-hidden={i >= logos.length ? 'true' : undefined}>
                {l.link ? (
                  <a href={l.link} target="_blank" rel="noopener" title={l.name}>
                    <SanityImage image={l.logo} alt={l.name} maxWidth={300} sizes="160px" plain />
                  </a>
                ) : (
                  <div title={l.name}>
                    <SanityImage image={l.logo} alt={l.name} maxWidth={300} sizes="160px" plain />
                  </div>
                )}
              </div>
            ))}
          </div>
        </div>
      </section>
    )
  }

  <div class="section-divider"><span>PROMEGA</span></div>

  <!-- Services / intro: image left + text right -->
  <section class="section">
    <div class="container two-col reveal">
      <div class="col-media">
        {introImage ? (
          <SanityImage
            image={introImage}
            alt="Promega Mimarlık"
            sizes="(max-width: 900px) 100vw, 45vw"
            maxWidth={1200}
          />
        ) : (
          <div class="placeholder">RESİM GELECEK!</div>
        )}
      </div>
      <div class="col-text">
        <p>{introText}</p>
        <a class="btn" href={introBtnLink}>{introBtnLabel}</a>
      </div>
    </div>
  </section>

  <div class="container"><hr class="rule" /></div>

  <!-- Projects -->
  {
    showcase.length > 0 && (
      <section class="section">
        <div class="container">
          <div class="row-head reveal">
            <h2>Projeler</h2>
            <a class="link-more" href="/projeler">
              Daha Fazla →
            </a>
          </div>
          <div class="proj-grid">
            {showcase.map((p) => (
              <ProjectCard project={p} />
            ))}
          </div>
        </div>
      </section>
    )
  }

  <div class="container"><hr class="rule" /></div>

  <!-- Hakkımızda: image left + title/text right -->
  <section class="section">
    <div class="container two-col reveal">
      <div class="col-media">
        {aboutImage ? (
          <SanityImage
            image={aboutImage}
            alt="Hakkımızda"
            sizes="(max-width: 900px) 100vw, 45vw"
            maxWidth={1200}
          />
        ) : (
          <div class="placeholder">RESİM GELECEK!</div>
        )}
      </div>
      <div class="col-text">
        <h2>{about.heading || 'Hakkımızda'}</h2>
        {about.body && about.body.length > 0 ? (
          <RichText value={about.body} />
        ) : (
          <p class="muted">Hakkımızda yazısı gelecek!</p>
        )}
      </div>
    </div>
  </section>

  <!-- Team: circular photos + bio popup -->
  {
    team.length > 0 && (
      <section class="section pt0">
        <div class="container team-row">
          {team.map((m, i) => (
            <div class="team-member reveal">
              <button class="avatar-btn" data-open={`hbio-${i}`} aria-label={`${m.name} biyografisi`}>
                <div class="avatar">
                  {m.photo?.asset?.url && (
                    <SanityImage
                      image={m.photo}
                      alt={m.name}
                      sizes="160px"
                      maxWidth={320}
                      aspect={1}
                    />
                  )}
                </div>
              </button>
              <p class="m-name">{m.name}</p>
              {m.jobTitle && <p class="m-role">{m.jobTitle.toLocaleUpperCase('tr-TR')}</p>}
              <button class="more-btn" data-open={`hbio-${i}`}>Biyografi →</button>

              <dialog class="bio-dialog" id={`hbio-${i}`}>
                <button class="bio-close" data-close aria-label="Kapat">&times;</button>
                <h2>{m.name}</h2>
                {m.jobTitle && <p class="bio-role">{m.jobTitle}</p>}
                {m.bio && m.bio.length > 0
                  ? <RichText value={m.bio} />
                  : <p style="color:var(--text-muted)">Biyografi yakında eklenecektir.</p>
                }
              </dialog>
            </div>
          ))}
        </div>
      </section>
    )
  }

</Base>

<style>
  /* Section divider: ─── PROMEGA ─── */
  .section-divider {
    display: flex;
    align-items: center;
    gap: 1.5rem;
    max-width: var(--maxw);
    margin-inline: auto;
    padding-inline: var(--gutter);
  }
  .section-divider::before,
  .section-divider::after {
    content: '';
    flex: 1;
    height: 1px;
    background: var(--border);
  }
  .section-divider span {
    font-size: 0.72rem;
    letter-spacing: 0.3em;
    color: var(--text-muted);
    flex-shrink: 0;
  }

  /* Plain hairline divider between sections */
  .rule {
    margin: 0;
    border: 0;
    border-top: 1px solid var(--border);
  }

  /* Two-column split */
  .two-col {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: clamp(2rem, 5vw, 4rem);
    align-items: center;
  }
  .col-media :global(img) {
    width: 100%;
    height: auto;
    border-radius: 4px;
  }
  .placeholder {
    aspect-ratio: 4 / 3;
    background: var(--bg-elevated-2);
    display: grid;
    place-items: center;
    border-radius: 4px;
    color: var(--text-muted);
    font-size: 0.85rem;
    letter-spacing: 0.1em;
  }
  .col-text {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }
  .col-text p {
    color: var(--text-muted);
    font-size: 1.05rem;
    line-height: 1.8;
    margin: 0;
  }
  .btn {
    display: inline-block;
    padding: 0.85rem 1.8rem;
    border: 1px solid var(--text);
    border-radius: 2px;
    font-size: 0.85rem;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    transition:
      background 0.3s var(--ease),
      color 0.3s var(--ease);
    align-self: flex-start;
  }
  .btn:hover {
    background: var(--accent);
    border-color: var(--accent);
    color: var(--bg);
  }

  /* Projects */
  .row-head {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 1rem;
    margin-bottom: 2rem;
  }
  .link-more {
    color: var(--text-muted);
    font-size: 0.9rem;
    letter-spacing: 0.04em;
    transition: color 0.25s var(--ease);
  }
  .link-more:hover {
    color: var(--accent);
  }
  .proj-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: clamp(0.75rem, 2vw, 1.5rem);
  }

  /* Team */
  .pt0 {
    padding-top: 0;
  }
  .team-row {
    display: flex;
    justify-content: center;
    gap: clamp(2rem, 5vw, 5rem);
    flex-wrap: wrap;
  }
  .team-member {
    text-align: center;
  }
  .avatar {
    width: 140px;
    height: 140px;
    border-radius: 50%;
    overflow: hidden;
    background: var(--bg-elevated-2);
    margin: 0 auto 1rem;
  }
  .avatar :global(img) {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .m-name {
    font-size: 0.9rem;
    letter-spacing: 0.04em;
    margin: 0 0 0.25rem;
    color: var(--text);
  }
  .m-role {
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    color: var(--text-muted);
    margin: 0 0 0.6rem;
  }
  .avatar-btn {
    background: none;
    border: 0;
    padding: 0;
    cursor: pointer;
    display: block;
    margin: 0 auto;
    border-radius: 50%;
    transition: transform 0.3s var(--ease);
  }
  .avatar-btn:hover { transform: scale(1.05); }
  .more-btn {
    background: none;
    border: 0;
    padding: 0;
    color: var(--text-muted);
    cursor: pointer;
    font-size: 0.8rem;
    letter-spacing: 0.06em;
    margin-top: 0.2rem;
    transition: color 0.25s var(--ease);
    display: block;
    width: 100%;
    text-align: center;
  }
  .more-btn:hover { color: var(--accent); }
  .bio-dialog {
    max-width: 680px;
    width: calc(100% - 2rem);
    background: var(--bg-elevated);
    color: var(--text);
    border: 1px solid var(--border);
    border-radius: 10px;
    padding: clamp(1.5rem, 4vw, 3rem);
    line-height: 1.8;
  }
  .bio-dialog::backdrop {
    background: rgba(10, 10, 10, 0.85);
    backdrop-filter: blur(4px);
  }
  .bio-dialog h2 { font-weight: 300; margin-bottom: 0.2rem; }
  .bio-role { color: var(--text-muted); font-size: 0.9rem; margin: 0 0 1.2rem; }
  .bio-close {
    position: absolute;
    top: 0.6rem;
    right: 1rem;
    background: none;
    border: 0;
    color: var(--text-muted);
    font-size: 2rem;
    cursor: pointer;
    line-height: 1;
  }
  .bio-close:hover { color: var(--text); }

  /* References — slow marquee */
  .refs-marquee {
    padding-block: clamp(1.6rem, 4vw, 2.6rem);
    background: #181818;
  }
  .refs-label {
    display: block;
    text-align: center;
    font-size: 0.72rem;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    color: var(--text-muted);
    margin-bottom: clamp(1.1rem, 3vw, 1.8rem);
  }
  .marquee {
    position: relative;
    overflow: hidden;
    /* Fade the logos out toward both edges */
    -webkit-mask-image: linear-gradient(
      90deg,
      transparent,
      #000 12%,
      #000 88%,
      transparent
    );
    mask-image: linear-gradient(90deg, transparent, #000 12%, #000 88%, transparent);
  }
  .marquee-track {
    display: flex;
    width: max-content;
    align-items: center;
    gap: clamp(2.5rem, 6vw, 5rem);
    animation: marquee 45s linear infinite;
  }
  .marquee:hover .marquee-track {
    animation-play-state: paused;
  }
  .marquee-item {
    flex: 0 0 auto;
    display: flex;
    align-items: center;
    justify-content: center;
    height: 60px;
  }
  .marquee-item a,
  .marquee-item > div {
    display: flex;
    align-items: center;
    justify-content: center;
    height: 100%;
  }
  .marquee-item :global(img) {
    width: auto;
    height: auto;
    max-height: 60px;
    max-width: 170px;
    object-fit: contain;
    filter: grayscale(1) brightness(2);
    opacity: 0.65;
    transition:
      opacity 0.3s var(--ease),
      filter 0.3s var(--ease);
    background: none !important;
  }
  .marquee-item a:hover :global(img) {
    opacity: 1;
    filter: grayscale(0);
  }
  @keyframes marquee {
    from {
      transform: translateX(0);
    }
    to {
      /* Track holds two copies; shifting by half loops seamlessly */
      transform: translateX(calc(-50% - clamp(1.25rem, 3vw, 2.5rem)));
    }
  }
  @media (prefers-reduced-motion: reduce) {
    .marquee-track {
      animation: none;
      flex-wrap: wrap;
      justify-content: center;
      width: 100%;
    }
  }

  .muted {
    color: var(--text-muted);
  }

  /* Responsive */
  @media (max-width: 1100px) {
    .proj-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
  @media (max-width: 900px) {
    .two-col {
      grid-template-columns: 1fr;
    }
  }
  @media (max-width: 640px) {
    .proj-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
</style>

<script>
  document.querySelectorAll<HTMLButtonElement>('[data-open]').forEach((btn) => {
    btn.addEventListener('click', () => {
      const dlg = document.getElementById(btn.dataset.open!) as HTMLDialogElement | null;
      dlg?.showModal();
    });
  });
  document.querySelectorAll<HTMLDialogElement>('.bio-dialog').forEach((dlg) => {
    dlg.querySelector('[data-close]')?.addEventListener('click', () => dlg.close());
    dlg.addEventListener('click', (e) => {
      const r = dlg.getBoundingClientRect();
      if (e.clientX < r.left || e.clientX > r.right || e.clientY < r.top || e.clientY > r.bottom)
        dlg.close();
    });
  });
</script>
